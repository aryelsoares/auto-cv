<?xml version="1.0" ?>

<!-- Category -->

<!--
Params can be changed to replace their names with custom ones.
All categories are optional except head.
-->

<category summary="" experiences="" projects="" educations="" skills="" languages="">
    <!-- Head -->

    <!--
    author: Your name.
    career: job.
    icon: Font Awesome's icon name.
    link: Full link.
    name: Link's name.
    line: Line position.
    -->

    <head author="Your Name" career="Profession" >
        <contact icon="Envelope" link="" name="My Email" line="1"/>
        <contact icon="Linkedin" link="https://www.linkedin.com/in/example/" name="My Linkedin" line="2"/>
        <contact icon="Github" link="https://github.com/example" name="My Github" line="2"/>
    </head>

    <!-- Summary -->

    <!-- area: Your description. -->

    <summary area="Your description."/>

    <!-- Experience -->

    <!--
    role: Role in the company.
    company: Company's name.
    date: Duration.
    text: Description of what you did at the company.
    -->

    <experiences>
        <experience role="Data Analyst" company="Facebook" date="2010 - 2014">
            <info text="I did this."/>
            <info text="And also that."/>
        </experience>
    </experiences>

    <!-- Projects -->

    <!--
    name: Project's name.
    ref icon/link/name: Same as head.
    text: Project's description.
    -->

    <projects>
        <project name="My Project">
            <refs>
                <ref icon="Globe" link="https://www.mypage.com/example/" name="Webpage"/>
                <ref icon="Github" link="https://github.com/name/myproject" name="Github"/>
            </refs>
            <description>
                <info text="I did this."/>
                <info text="And also that."/>
            </description>
        </project>
    </projects>

    <!-- Education -->

    <!--
    field: Academic background.
    institution: Name of the place where you studied.
    date: Duration.
    local: Regional position.
    grade: Additional information.
    -->

    <educations>
        <education field="Software Engineering" institution="Harvard" date="2006 - 2010" local="Cambridge, EUA" grade="Description."/>
    </educations>

    <!-- Skills -->

    <!--
    field name: Field related to skill.
    skill name: Self explanatory.
    -->

    <skills>
        <field name="Backend">
            <skill name="Python"/>
            <skill name="Rust"/>
            <skill name="Java"/>
        </field>
        <field name="Frontend">
            <skill name="HTML"/>
            <skill name="CSS"/>
            <skill name="Javascript"/>
        </field>
    </skills>
    
    <!-- Languages -->
    
    <!--
    name: Name of the language.
    level: Native, advanced, intermediate...
    desc: Additional information. (optional)
    -->
    
    <languages>
        <language name="English" level="Native"/>
        <language name="Spanish" level="Intermediate" desc="Description"/>
    </languages>
</category>
